import("sheep-farm/hayplot" as= gg)

// Demonstração de múltiplas séries (NOVO v1.3.0)
// Este exemplo mostra como plotar múltiplas séries no mesmo gráfico
// Útil para visualizações como DiD (Difference-in-Differences)

// Nota: Este exemplo requer dados externos para funcionar
// Para testar, use seu próprio dataset com múltiplas colunas no eixo x

